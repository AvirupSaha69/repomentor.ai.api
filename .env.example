# API Server Configurations
HOST=0.0.0.0
PORT=8000
DEBUG=true

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=repomentor

# GitHub Configuration
# Generate a Personal Access Token (PAT) with appropriate scopes (repo, read:user, etc.)
# Fallback environment variables: GITHUB_PAT_TOKEN or "GITHUB _PAT_TOKEN" are also checked.
GITHUB_TOKEN=your_github_personal_access_token_here

# Gemini API Configuration
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Authentication Configuration
# Use a secure random string (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

